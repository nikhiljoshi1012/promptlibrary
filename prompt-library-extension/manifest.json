{
  "manifest_version": 3,
  "name": "Prompt Library",
  "version": "2.0.0",
  "description": "Save, organize, search, and copy AI prompts with ease",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "clipboardWrite",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
